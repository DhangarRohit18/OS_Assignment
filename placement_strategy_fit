#include <iostream>

using namespace std;

void firstFit(int blocks[],
              int m,
              int process[],
              int n)
{
    int allocation[n];

    
    for(int i = 0; i < n; i++)
    {
        allocation[i] = -1;
    }

    
    for(int i = 0; i < n; i++)
    {
        for(int j = 0; j < m; j++)
        {
            if(blocks[j] >= process[i])
            {
                allocation[i] = j;

                blocks[j] -= process[i];

                break;
            }
        }
    }

    
    cout << "\nFirst Fit Allocation:\n";

    for(int i = 0; i < n; i++)
    {
        if(allocation[i] != -1)
        {
            cout << "P" << i + 1
                 << " -> Block "
                 << allocation[i] + 1
                 << endl;
        }
        else
        {
            cout << "P" << i + 1
                 << " -> Not Allocated\n";
        }
    }
}

void bestFit(int blocks[],
             int m,
             int process[],
             int n)
{
    int allocation[n];

    
    for(int i = 0; i < n; i++)
    {
        allocation[i] = -1;
    }

    
    for(int i = 0; i < n; i++)
    {
        int bestIdx = -1;

        for(int j = 0; j < m; j++)
        {
            if(blocks[j] >= process[i])
            {
                if(bestIdx == -1 ||
                   blocks[j] < blocks[bestIdx])
                {
                    bestIdx = j;
                }
            }
        }

        
        if(bestIdx != -1)
        {
            allocation[i] = bestIdx;

            blocks[bestIdx] -= process[i];
        }
    }

    
    cout << "\nBest Fit Allocation:\n";

    for(int i = 0; i < n; i++)
    {
        if(allocation[i] != -1)
        {
            cout << "P" << i + 1
                 << " -> Block "
                 << allocation[i] + 1
                 << endl;
        }
        else
        {
            cout << "P" << i + 1
                 << " -> Not Allocated\n";
        }
    }
}

void worstFit(int blocks[],
              int m,
              int process[],
              int n)
{
    int allocation[n];

    
    for(int i = 0; i < n; i++)
    {
        allocation[i] = -1;
    }

    
    for(int i = 0; i < n; i++)
    {
        int worstIdx = -1;

        for(int j = 0; j < m; j++)
        {
            if(blocks[j] >= process[i])
            {
                if(worstIdx == -1 ||
                   blocks[j] > blocks[worstIdx])
                {
                    worstIdx = j;
                }
            }
        }

        
        if(worstIdx != -1)
        {
            allocation[i] = worstIdx;

            blocks[worstIdx] -= process[i];
        }
    }

    
    cout << "\nWorst Fit Allocation:\n";

    for(int i = 0; i < n; i++)
    {
        if(allocation[i] != -1)
        {
            cout << "P" << i + 1
                 << " -> Block "
                 << allocation[i] + 1
                 << endl;
        }
        else
        {
            cout << "P" << i + 1
                 << " -> Not Allocated\n";
        }
    }
}

int main()
{
    int m, n;

    
    cout << "Enter number of memory blocks: ";

    cin >> m;

    int originalBlocks[m];

    
    cout << "Enter size of each block (in KB):\n";

    for(int i = 0; i < m; i++)
    {
        cin >> originalBlocks[i];
    }

    
    cout << "Enter number of processes: ";

    cin >> n;

    int process[n];

    
    cout << "Enter size of each process (in KB):\n";

    for(int i = 0; i < n; i++)
    {
        cin >> process[i];
    }

    int choice;

    do
    {
        
        int blocks[m];

        for(int i = 0; i < m; i++)
        {
            blocks[i] = originalBlocks[i];
        }

        
        cout << "\n--- Menu ---\n";

        cout << "1. First Fit\n";
        cout << "2. Best Fit\n";
        cout << "3. Worst Fit\n";
        cout << "4. Exit\n";

        cout << "Enter your choice: ";

        cin >> choice;

        switch(choice)
        {
            case 1:
                firstFit(blocks, m, process, n);
                break;

            case 2:
                bestFit(blocks, m, process, n);
                break;

            case 3:
                worstFit(blocks, m, process, n);
                break;

            case 4:
                cout << "Exiting...\n";
                break;

            default:
                cout << "Invalid choice!\n";
        }

    } while(choice != 4);

    return 0;
}